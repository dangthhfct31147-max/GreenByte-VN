
# Environment (set to 'production' on Railway)
NODE_ENV=development

# Database (Prisma)
# For Prisma Accelerate runtime (after enabling in console.prisma.io)
# Example: prisma://accelerate.prisma-data.net/?api_key=__API_KEY__&schema=eco
DATABASE_URL=

# Direct database connection string (required for prisma db push / migrate / introspect)
# Example (CockroachDB): postgresql://USER:PASSWORD@HOST:26257/DB?sslmode=require&schema=eco
DIRECT_DATABASE_URL=

# Backend
PORT=3001
FRONTEND_ORIGIN=http://localhost:5173

# Optional: allow multiple web origins (comma-separated) for CORS/CSRF
# Example: https://greenbyte-production.up.railway.app,https://greenbyte-admin.up.railway.app
CORS_ALLOWED_ORIGINS=

# Optional explicit admin web origin
ADMIN_ORIGIN=

# Auth
# Use a long random string (>= 32 chars) - GENERATE A NEW SECRET FOR PRODUCTION!
# Example: openssl rand -hex 48
JWT_SECRET=

# TOTP 2FA Issuer name (shown in authenticator apps)
TOTP_ISSUER=GreenByte VN

# Admin portal credentials
# Option A (dev): use plain ADMIN_PASSWORD
ADMIN_EMAIL=admin@greenbyte.vn
ADMIN_PASSWORD=

# Optional: show demo credentials in Admin login UI (frontend)
VITE_ADMIN_DEMO_EMAIL=admin@greenbyte.vn
VITE_ADMIN_DEMO_PASSWORD=

# Option B (recommended): use bcrypt hash and leave ADMIN_PASSWORD empty
# Example hash: node -e "require('bcryptjs').hash('YourStrongPassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=

# Optional separate secret for admin JWT (fallbacks to JWT_SECRET when empty)
ADMIN_JWT_SECRET=

# ============================================
# RAILWAY DEPLOYMENT NOTES:
# ============================================
# 1. Set NODE_ENV=production
# 2. Set FRONTEND_ORIGIN to your Railway frontend URL
# 3. Generate a new JWT_SECRET for production:
#    openssl rand -hex 48
# 4. Configure DATABASE_URL in Railway dashboard
# ============================================

# ============================================
# BLOCKCHAIN (Polygon Amoy Testnet)
# ============================================
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
DEPLOYER_PRIVATE_KEY=0x92aecC34409cD0Eaf652390237141b3628783e85
BYPRODUCT_REGISTRY_ADDRESS=
ESCROW_CONTRACT_ADDRESS=
GREEN_TOKEN_ADDRESS=
CHAIN_ID=80002

